# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────
# WATCHLIST & BEHAVIOR
# ─────────────────────────────────────────────
WATCHLIST=AAPL,NVDA,TSLA,Fed rates,semiconductors
SENSITIVITY=medium          # high | medium | low
MIN_IMPACT=medium           # only alert on this level and above
SCAN_INTERVAL_MINUTES=30    # how often to scan (local/server mode)
MARKET_HOURS_ONLY=true      # skip scans outside NYSE hours (Mon-Fri 9:30-16:00 ET)

# ─────────────────────────────────────────────
# NOTIFICATIONS  — fill in the ones you want
# ─────────────────────────────────────────────

# Slack (easiest — just paste your Incoming Webhook URL)
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email via SendGrid (free up to 100 emails/day)
# Sign up at: https://sendgrid.com
SENDGRID_API_KEY=SG.your-key-here
EMAIL_FROM=alerts@yourdomain.com
EMAIL_TO=you@example.com

# Email via SMTP (e.g. Gmail — needs an App Password, not your regular password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# SMS via Twilio (~$0.01/text after free trial)
# Sign up at: https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543
